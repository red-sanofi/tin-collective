# Copy to .env for local development.
# Production store builds: EXPO_PUBLIC_API_URL=https://api.tinkolektif.org
# See docs/URLS-AND-CONFIG.md

# Local Docker API (make build) — iOS Simulator
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Android Emulator (uncomment instead of line above):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# Physical device on same Wi‑Fi (replace with your PC IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8000

# Production:
# EXPO_PUBLIC_API_URL=https://api.tinkolektif.org
