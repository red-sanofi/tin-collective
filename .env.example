POSTGRES_DB=tin_collective
POSTGRES_USER=tin_collective
POSTGRES_PASSWORD=tin_collective

DJANGO_SECRET_KEY=dev-secret-key-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Local development defaults
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8000
SITE_DOMAIN=localhost:8000
API_SITE_DOMAIN=localhost:8000
VITE_API_URL=http://localhost:8000

# Production example (copy deploy/.env.production.example or see deploy/README.md):
# DJANGO_DEBUG=false
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,tinkolektif.org,www.tinkolektif.org,api.tinkolektif.org,admin.tinkolektif.org
# CORS_ALLOWED_ORIGINS=https://tinkolektif.org,https://www.tinkolektif.org
# CSRF_TRUSTED_ORIGINS=https://admin.tinkolektif.org
# FRONTEND_URL=https://tinkolektif.org
# BACKEND_PUBLIC_URL=https://api.tinkolektif.org
# SITE_DOMAIN=tinkolektif.org
# API_SITE_DOMAIN=api.tinkolektif.org
# VITE_API_URL=https://api.tinkolektif.org

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Local redirect URI: http://localhost:8000/auth/social/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
# Local callback URL: http://localhost:8000/auth/social/github/login/callback/
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: live Instagram feed sync for the homepage (Meta Graph API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
SOCIAL_INSTAGRAM_HANDLE=tinkolektif
