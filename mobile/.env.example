# Mobile environment — copy to .env
# See docs/PRODUCTION.md and docs/URLS-AND-CONFIG.md

# --- Production (Expo Go or store build) ---
EXPO_PUBLIC_API_URL=https://api.tinkolektif.org

# --- Local Docker (uncomment one, comment production line above) ---
# iOS Simulator:
# EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
# Android Emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000
# Physical phone (same Wi‑Fi as dev machine):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8000
