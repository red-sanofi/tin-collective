POSTGRES_DB=tin_collective
POSTGRES_USER=tin_collective
POSTGRES_PASSWORD=tin_collective

DJANGO_SECRET_KEY=dev-secret-key-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Local development (Docker: make build → http://localhost:8080)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:8000

FRONTEND_URL=http://localhost:8080
BACKEND_PUBLIC_URL=http://localhost:8000
SITE_DOMAIN=localhost:8000
API_SITE_DOMAIN=localhost:8000
VITE_API_URL=http://localhost:8000

# Bare Vite only (npm run dev in frontend/, no Docker): use port 5173
# FRONTEND_URL=http://localhost:5173

# Production server: copy .env.production.example to .env on the server instead.
# See docs/URLS-AND-CONFIG.md and deploy/README.md

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Local redirect URI: http://localhost:8000/auth/social/google/login/callback/
# Production:         https://api.tinkolektif.org/auth/social/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
# Local callback: http://localhost:8000/auth/social/github/login/callback/
# Production:     https://api.tinkolektif.org/auth/social/github/login/callback/
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: live Instagram feed sync for the homepage (Meta Graph API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
SOCIAL_INSTAGRAM_HANDLE=tinkolektif
